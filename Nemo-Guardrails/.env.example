# Copy this file to `.env` and fill in your keys. `.env` is git-ignored.

# OpenAI — powers the main ARIA LLM (gpt-3.5-turbo) and the self-check rails.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# NVIDIA — required for the NIM-backed rails (Content Safety, GLiNER PII).
# Get one at https://build.nvidia.com
NVIDIA_API_KEY=
